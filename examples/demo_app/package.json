{
  "name": "demo_app",
  "version": "0.1.0",
  "description": "Demo App - Person Management with Dioxus",
  "scripts": {
    "build": "tailwindcss -i ./assets/input.css -o ./assets/tailwind.css",
    "watch": "tailwindcss -i ./assets/input.css -o ./assets/tailwind.css --watch",
    "dev": "concurrently \"npm run watch\" \"dx serve\"",
